{
  "components": {
    "copyButton": {
      "dark": {
        "background": {
          "$value": "{color.black.20}",
          "hover": { "$value": "{color.black.10}" }
        },

        "text": {
          "$value": "{text.dark.muted}",
          "hover": { "$value": "{text.dark.primary}" }
        }
      },

      "light": {
        "background": {
          "$value": "{color.white.20}",
          "hover": { "$value": "{color.white.10}" }
        },

        "text": {
          "$value": "{text.light.muted}",
          "hover": { "$value": "{text.light.primary}" }
        }
      }
    }
  }
}
