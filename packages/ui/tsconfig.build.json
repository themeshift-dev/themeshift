{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/index.ts",
    "src/entrypoints/**/*.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/templates/**/*.ts",
    "src/templates/**/*.tsx",
    "src/icons/**/*.ts",
    "src/icons/**/*.tsx",
    "src/hooks/**/*.ts",
    "src/hooks/**/*.tsx",
    "src/contexts/**/*.ts",
    "src/contexts/**/*.tsx"
  ],
  "exclude": [
    "src/main.tsx",
    "src/App.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/components/Menu/components/**/*.ts",
    "src/components/Menu/components/**/*.tsx",
    "src/components/Menu/internal/**/*.ts",
    "src/components/Menu/internal/**/*.tsx",
    "src/components/Menu/test-utils.tsx",
    ".storybook/**"
  ]
}
