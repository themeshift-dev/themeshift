{
  "zIndex": {
    "0": { "$type": "number", "$value": 0 },
    "10": { "$type": "number", "$value": 10 },
    "20": { "$type": "number", "$value": 20 },
    "30": { "$type": "number", "$value": 30 },
    "40": { "$type": "number", "$value": 40 },
    "50": { "$type": "number", "$value": 50 }
  },

  "layer": {
    "base": { "$type": "number", "$value": "{zIndex.0}" },
    "raised": { "$type": "number", "$value": "{zIndex.10}" },
    "sticky": { "$type": "number", "$value": "{zIndex.20}" },
    "overlay": { "$type": "number", "$value": "{zIndex.30}" },
    "popover": { "$type": "number", "$value": "{zIndex.40}" },
    "modal": { "$type": "number", "$value": "{zIndex.50}" }
  }
}
