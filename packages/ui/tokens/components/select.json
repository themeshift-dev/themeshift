{
  "components": {
    "select": {
      "layout": {
        "chevronInsetInlineEnd": { "$value": "{space.3}" },
        "paddingInlineEnd": { "$value": "{space.9}" }
      },

      "size": {
        "small": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{size.control.small.height}" },
          "paddingInline": { "$value": "{size.control.small.paddingInline}" }
        },

        "medium": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{size.control.medium.height}" },
          "paddingInline": { "$value": "{size.control.medium.paddingInline}" }
        },

        "large": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{size.control.large.height}" },
          "paddingInline": { "$value": "{size.control.large.paddingInline}" }
        }
      },

      "light": {
        "background": { "$value": "{color.white}" },
        "border": { "$value": "{color.black.20}" },
        "chevron": { "$value": "{color.black.70}" },
        "disabled": {
          "background": { "$value": "{color.gray.100}" },
          "border": { "$value": "{color.black.10}" },
          "chevron": { "$value": "{color.black.40}" },
          "text": { "$value": "{color.black.50}" }
        },

        "validation": {
          "invalid": { "border": { "$value": "{color.red.400}" } },
          "valid": { "border": { "$value": "{color.green.400}" } },
          "warning": { "border": { "$value": "{color.lightBlue.400}" } }
        }
      },

      "dark": {
        "background": { "$value": "{color.white.10}" },
        "border": { "$value": "{color.white.20}" },
        "chevron": { "$value": "{color.white.70}" },
        "disabled": {
          "background": { "$value": "{color.white.10}" },
          "border": { "$value": "{color.white.10}" },
          "chevron": { "$value": "{color.white.40}" },
          "text": { "$value": "{color.white.50}" }
        },

        "validation": {
          "invalid": { "border": { "$value": "{color.red.400}" } },
          "valid": { "border": { "$value": "{color.green.400}" } },
          "warning": { "border": { "$value": "{color.lightBlue.400}" } }
        }
      }
    }
  }
}
