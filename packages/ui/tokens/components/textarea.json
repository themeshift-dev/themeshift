{
  "components": {
    "textarea": {
      "size": {
        "small": {
          "borderRadius": { "$value": "{radius.small}" },
          "minHeight": { "$value": "{space.16}" },
          "padding": { "$value": "{space.3}" }
        },

        "medium": {
          "borderRadius": { "$value": "{radius.small}" },
          "minHeight": { "$value": "{space.20}" },
          "padding": { "$value": "{space.4}" }
        },

        "large": {
          "borderRadius": { "$value": "{radius.small}" },
          "minHeight": { "$value": "{space.24}" },
          "padding": { "$value": "{space.5}" }
        }
      },

      "light": {
        "background": { "$value": "{color.white}" },
        "border": { "$value": "{color.black.20}" },
        "placeholder": { "$value": "{color.black.50}" },
        "disabled": {
          "background": { "$value": "{color.gray.100}" },
          "border": { "$value": "{color.black.10}" },
          "text": { "$value": "{color.black.50}" },
          "placeholder": { "$value": "{color.black.40}" }
        },

        "validation": {
          "invalid": { "border": { "$value": "{color.red.400}" } },
          "valid": { "border": { "$value": "{color.green.400}" } },
          "warning": { "border": { "$value": "{color.lightBlue.400}" } }
        }
      },

      "dark": {
        "background": { "$value": "{color.white.10}" },
        "border": { "$value": "{color.white.20}" },
        "placeholder": { "$value": "{color.white.50}" },
        "disabled": {
          "background": { "$value": "{color.white.10}" },
          "border": { "$value": "{color.white.10}" },
          "text": { "$value": "{color.white.50}" },
          "placeholder": { "$value": "{color.white.40}" }
        },

        "validation": {
          "invalid": { "border": { "$value": "{color.red.400}" } },
          "valid": { "border": { "$value": "{color.green.400}" } },
          "warning": { "border": { "$value": "{color.lightBlue.400}" } }
        }
      }
    }
  }
}
