{
  "components": {
    "skiplink": {
      "font": { "$value": "{font.family.sans}" },
      "x": { "$type": "dimension", "$value": "1rem" },
      "y": { "$type": "dimension", "$value": "1rem" },
      "borderRadius": { "$type": "dimension", "$value": "{radius.small}" },
      "light": {
        "background": { "$value": "{color.blue.400}" },
        "text": { "$value": "{color.blue.400.text}" }
      },

      "dark": {
        "background": { "$value": "{color.blue.400}" },
        "text": { "$value": "{color.blue.400.text}" }
      }
    }
  }
}
