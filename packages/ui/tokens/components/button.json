{
  "components": {
    "button": {
      "padding": { "$value": "0 {space.4}" },
      "font": { "$value": "{font.family.sans}" },

      "sizes": {
        "small": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{space.8}" },

          "padding": {
            "$value": "0 {space.4}",

            "iconOnly": { "$value": "0 {space.2}" }
          }
        },

        "medium": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{space.9}" },

          "padding": {
            "$value": "0 {space.6}",

            "iconOnly": { "$value": "0 {space.3}" }
          }
        },

        "large": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{space.10}" },

          "padding": {
            "$value": "0 {space.8}",

            "iconOnly": { "$value": "0 {space.4}" }
          }
        }
      },

      "intents": {
        "light": {
          "primary": {
            "bg": { "$value": "{color.blue.400}" },
            "fg": { "$value": "{color.blue.400.fg}" },
            "hover": { "$value": "{color.blue.300}" }
          },

          "secondary": {
            "bg": { "$value": "{color.gray.400}" },
            "fg": { "$value": "{color.gray.400.fg}" },
            "hover": { "$value": "{color.gray.300}" }
          },

          "constructive": {
            "bg": { "$value": "{color.green.400}" },
            "fg": { "$value": "{color.green.400.fg}" },
            "hover": { "$value": "{color.green.300}" }
          },

          "destructive": {
            "bg": { "$value": "{color.red.400}" },
            "fg": { "$value": "{color.red.400.fg}" },
            "hover": { "$value": "{color.red.300}" }
          }
        },

        "dark": {
          "primary": {
            "bg": { "$value": "{color.blue.400}" },
            "fg": { "$value": "{color.blue.400.fg}" },
            "hover": { "$value": "lighten({color.blue.400}, .1)" }
          },

          "secondary": {
            "bg": { "$value": "{color.gray.400}" },
            "fg": { "$value": "{color.gray.400.fg}" },
            "hover": { "$value": "{color.gray.300}" }
          },

          "constructive": {
            "bg": { "$value": "{color.green.400}" },
            "fg": { "$value": "{color.green.400.fg}" },
            "hover": { "$value": "{color.green.300}" }
          },

          "destructive": {
            "bg": { "$value": "{color.red.400}" },
            "fg": { "$value": "{color.red.400.fg}" },
            "hover": { "$value": "{color.red.300}" }
          }
        }
      }
    }
  }
}
