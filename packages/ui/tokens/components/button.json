{
  "components": {
    "button": {
      "font": { "$value": "{font.family.sans}" },
      "padding": { "$value": "0 {space.4}" },
      "size": {
        "small": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{size.control.small.height}" },
          "padding": {
            "$value": "0 {size.control.small.paddingInline}",

            "iconOnly": { "$value": "0 {space.2}" }
          }
        },

        "medium": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{size.control.medium.height}" },
          "padding": {
            "$value": "0 {size.control.medium.paddingInline}",

            "iconOnly": { "$value": "0 {space.3}" }
          }
        },

        "large": {
          "borderRadius": { "$value": "{radius.small}" },
          "height": { "$value": "{size.control.large.height}" },
          "padding": {
            "$value": "0 {size.control.large.paddingInline}",

            "iconOnly": { "$value": "0 {space.4}" }
          }
        },

        "hero": {
          "borderRadius": {
            "min": { "$value": "{radius.small}" },
            "fluid": { "$value": "0.7vw" },
            "max": { "$value": "{radius.medium}" }
          },

          "fontSize": {
            "min": { "$value": "{typography.label.medium.fontSize}" },
            "fluid": { "$value": "0.4vw + 0.92rem" },
            "max": { "$value": "{typography.heading.small.fontSize}" }
          },

          "height": {
            "min": { "$value": "{space.9}" },
            "fluid": { "$value": "1.3vw + 2.2rem" },
            "max": { "$value": "{space.12}" }
          },

          "letterSpacing": {
            "min": { "$value": "{typography.label.medium.letterSpacing}" },
            "fluid": { "$value": "0.002vw + 0.0095em" },
            "max": { "$value": "{typography.heading.small.letterSpacing}" }
          },

          "lineHeight": {
            "min": { "$value": "{typography.label.medium.lineHeight}" },
            "fluid": { "$value": "0.25vw + 1.25rem" },
            "max": { "$value": "{typography.heading.small.lineHeight}" }
          },

          "padding": {
            "inline": {
              "min": { "$value": "{space.6}" },
              "fluid": { "$value": "1.8vw + 0.85rem" },
              "max": { "$value": "{space.10}" }
            },

            "iconOnly": {
              "inline": {
                "min": { "$value": "{space.3}" },
                "fluid": { "$value": "0.9vw + 0.5rem" },
                "max": { "$value": "{space.5}" }
              }
            }
          }
        }
      },

      "variant": {
        "light": {
          "primary": {
            "background": { "$value": "{color.blue.400}" },
            "text": { "$value": "{color.blue.400.text}" },
            "hover": { "$value": "{color.blue.300}" }
          },

          "secondary": {
            "background": { "$value": "{color.gray.400}" },
            "text": { "$value": "{color.gray.400.text}" },
            "hover": { "$value": "{color.gray.300}" }
          },

          "constructive": {
            "background": { "$value": "{color.green.400}" },
            "text": { "$value": "{color.green.400.text}" },
            "hover": { "$value": "{color.green.300}" }
          },

          "destructive": {
            "background": { "$value": "{color.red.400}" },
            "text": { "$value": "{color.red.400.text}" },
            "hover": { "$value": "{color.red.300}" }
          }
        },

        "dark": {
          "primary": {
            "background": { "$value": "{color.blue.400}" },
            "text": { "$value": "{color.blue.400.text}" },
            "hover": { "$value": "lighten({color.blue.400}, .1)" }
          },

          "secondary": {
            "background": { "$value": "{color.gray.400}" },
            "text": { "$value": "{color.gray.400.text}" },
            "hover": { "$value": "{color.gray.300}" }
          },

          "constructive": {
            "background": { "$value": "{color.green.400}" },
            "text": { "$value": "{color.green.400.text}" },
            "hover": { "$value": "{color.green.300}" }
          },

          "destructive": {
            "background": { "$value": "{color.red.400}" },
            "text": { "$value": "{color.red.400.text}" },
            "hover": { "$value": "{color.red.300}" }
          }
        }
      }
    }
  }
}
