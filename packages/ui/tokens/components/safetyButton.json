{
  "components": {
    "safetyButton": {
      "hold": {
        "light": {
          "background": { "$value": "{color.gray.200}" },
          "text": { "$value": "{color.gray.900}" }
        },

        "dark": {
          "background": { "$value": "{color.gray.800}" },
          "text": { "$value": "{color.gray.50}" }
        }
      },

      "variant": {
        "light": {
          "primary": {
            "fill": {
              "$value": "{components.button.variant.light.primary.background}"
            }
          },

          "secondary": {
            "fill": {
              "$value": "{components.button.variant.light.secondary.background}"
            }
          },
          "tertiary": { "fill": { "$value": "{color.gray.300}" } },
          "constructive": {
            "fill": {
              "$value": "{components.button.variant.light.constructive.background}"
            }
          },

          "destructive": {
            "fill": {
              "$value": "{components.button.variant.light.destructive.background}"
            }
          }
        },

        "dark": {
          "primary": {
            "fill": {
              "$value": "{components.button.variant.dark.primary.background}"
            }
          },

          "secondary": {
            "fill": {
              "$value": "{components.button.variant.dark.secondary.background}"
            }
          },
          "tertiary": { "fill": { "$value": "{color.gray.700}" } },
          "constructive": {
            "fill": {
              "$value": "{components.button.variant.dark.constructive.background}"
            }
          },

          "destructive": {
            "fill": {
              "$value": "{components.button.variant.dark.destructive.background}"
            }
          }
        }
      }
    }
  }
}
