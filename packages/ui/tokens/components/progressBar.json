{
  "components": {
    "progressBar": {
      "layout": {
        "gap": { "$value": "{space.2}" },
        "descriptionColor": { "$value": "{color.gray.600}" },
        "labelColor": { "$value": "{color.gray.900}" },
        "trackBg": { "$value": "{color.gray.200}" },
        "valueColor": { "$value": "{color.gray.900}" }
      },

      "radius": {
        "none": { "$value": "0" },
        "small": { "$value": "{radius.small}" },
        "medium": { "$value": "{radius.medium}" },
        "large": { "$value": "{radius.large}" },
        "full": { "$value": "999px" }
      },

      "sizes": {
        "small": {
          "trackBlock": { "$value": "0.375rem" },
          "verticalTrackBlock": { "$value": "6rem" },
          "verticalTrackInline": { "$value": "0.375rem" }
        },
        "medium": {
          "trackBlock": { "$value": "0.5rem" },
          "verticalTrackBlock": { "$value": "7.5rem" },
          "verticalTrackInline": { "$value": "0.5rem" }
        },
        "large": {
          "trackBlock": { "$value": "0.625rem" },
          "verticalTrackBlock": { "$value": "9rem" },
          "verticalTrackInline": { "$value": "0.625rem" }
        }
      },

      "tones": {
        "light": {
          "primary": {
            "fill": { "$value": "{components.button.intents.light.primary.bg}" }
          },
          "secondary": {
            "fill": {
              "$value": "{components.button.intents.light.secondary.bg}"
            }
          },
          "constructive": {
            "fill": {
              "$value": "{components.button.intents.light.constructive.bg}"
            }
          },
          "destructive": {
            "fill": {
              "$value": "{components.button.intents.light.destructive.bg}"
            }
          }
        },

        "dark": {
          "primary": {
            "fill": { "$value": "{components.button.intents.dark.primary.bg}" }
          },
          "secondary": {
            "fill": {
              "$value": "{components.button.intents.dark.secondary.bg}"
            }
          },
          "constructive": {
            "fill": {
              "$value": "{components.button.intents.dark.constructive.bg}"
            }
          },
          "destructive": {
            "fill": {
              "$value": "{components.button.intents.dark.destructive.bg}"
            }
          }
        }
      }
    }
  }
}
