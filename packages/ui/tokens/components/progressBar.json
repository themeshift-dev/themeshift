{
  "components": {
    "progressBar": {
      "layout": {
        "gap": { "$value": "{space.2}" },
        "descriptionColor": { "$value": "{color.gray.600}" },
        "labelColor": { "$value": "{color.gray.900}" },
        "trackBackground": { "$value": "{color.gray.200}" },
        "valueColor": { "$value": "{color.gray.900}" }
      },

      "radius": {
        "none": { "$value": "0" },
        "small": { "$value": "{radius.small}" },
        "medium": { "$value": "{radius.medium}" },
        "large": { "$value": "{radius.large}" },
        "full": { "$value": "999px" }
      },

      "size": {
        "small": {
          "trackBlock": { "$value": "0.375rem" },
          "verticalTrackBlock": { "$value": "6rem" },
          "verticalTrackInline": { "$value": "0.375rem" }
        },

        "medium": {
          "trackBlock": { "$value": "0.5rem" },
          "verticalTrackBlock": { "$value": "7.5rem" },
          "verticalTrackInline": { "$value": "0.5rem" }
        },

        "large": {
          "trackBlock": { "$value": "0.625rem" },
          "verticalTrackBlock": { "$value": "9rem" },
          "verticalTrackInline": { "$value": "0.625rem" }
        }
      },

      "variant": {
        "light": {
          "primary": {
            "fill": { "$value": "{intent.light.primary.background}" }
          },

          "secondary": {
            "fill": { "$value": "{intent.light.secondary.background}" }
          },

          "constructive": {
            "fill": { "$value": "{intent.light.constructive.background}" }
          },

          "destructive": {
            "fill": { "$value": "{intent.light.destructive.background}" }
          }
        },

        "dark": {
          "primary": {
            "fill": { "$value": "{intent.dark.primary.background}" }
          },

          "secondary": {
            "fill": { "$value": "{intent.dark.secondary.background}" }
          },

          "constructive": {
            "fill": { "$value": "{intent.dark.constructive.background}" }
          },

          "destructive": {
            "fill": { "$value": "{intent.dark.destructive.background}" }
          }
        }
      }
    }
  }
}
