{
  "components": {
    "navbar": {
      "minHeight": {
        "$type": "dimension",
        "$value": "72px"
      },
      "padding": {
        "inline": {
          "$value": "0"
        },
        "block": {
          "$value": "0"
        }
      },
      "container": {
        "maxWidth": {
          "$value": "{grid.container.contentMaxWidth}"
        },
        "paddingInline": {
          "mobile": {
            "$value": "{grid.container.paddingInline.mobile}"
          },
          "tablet": {
            "$value": "{grid.container.paddingInline.tablet}"
          },
          "desktop": {
            "$value": "{grid.container.paddingInline.desktop}"
          }
        },
        "gap": {
          "$value": "{space.8}"
        }
      },
      "section": {
        "gap": {
          "$value": "{space.4}"
        }
      },
      "light": {
        "bg": {
          "$value": "transparent"
        },
        "border": {
          "$value": "transparent"
        }
      },
      "dark": {
        "bg": {
          "$value": "transparent"
        },
        "border": {
          "$value": "transparent"
        }
      }
    }
  }
}
