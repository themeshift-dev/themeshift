{
  "components": {
    "tooltip": {
      "paddingX": { "$value": "{space.3}" },
      "paddingY": { "$value": "{space.2}" },
      "radius": { "$value": "{radius.small}" },
      "maxWidth": { "$value": "20rem" },
      "shadow": { "$value": "{shadow.medium}" },
      "zIndex": { "$type": "number", "$value": "{layer.overlay}" },

      "arrow": { "size": { "$value": "10px" } },

      "border": { "width": { "$value": "1px" } },

      "light": {
        "background": { "$value": "{color.gray.100}" },
        "text": { "$value": "{text.light.primary}" },
        "border": {
          "color": { "$value": "{components.tooltip.light.background}" }
        }
      },

      "dark": {
        "surface": { "$value": "{color.black.40}" },
        "background": { "$value": "{components.tooltip.dark.surface}" },
        "text": { "$value": "{text.dark.primary}" },
        "border": {
          "color": { "$value": "{components.tooltip.dark.background}" }
        }
      }
    }
  }
}
