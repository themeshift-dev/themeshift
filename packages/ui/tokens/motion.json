{
  "duration": {
    "fast": { "$type": "duration", "$value": "120ms" },
    "medium": { "$type": "duration", "$value": "200ms" },
    "slow": { "$type": "duration", "$value": "320ms" }
  },

  "easing": {
    "standard": {
      "$type": "cubicBezier",
      "$value": "cubic-bezier(0.2, 0, 0, 1)"
    },

    "emphasized": {
      "$type": "cubicBezier",
      "$value": "cubic-bezier(0.2, 0, 0, 1.2)"
    }
  }
}
