      "mediumStrong": {
        "fontSize": { "$type": "fontSize", "$value": "1rem" },
        "lineHeight": { "$type": "lineHeight", "$value": "1.375rem" },
        "letterSpacing": { "$type": "letterSpacing", "$value": "0.01em" },
        "fontWeight": {
          "$type": "fontWeight",
          "$value": "{font.weight.semiBold}"
