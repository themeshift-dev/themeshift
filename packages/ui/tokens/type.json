      "large": {
        "fontSize": { "$type": "fontSize", "$value": "1.125rem" },
        "lineHeight": { "$type": "lineHeight", "$value": "1.5rem" },
        "letterSpacing": { "$type": "letterSpacing", "$value": "0.01em" },
        "fontWeight": {
          "$type": "fontWeight",
          "$value": "{font.weight.regular}"
        },
        "fontStyle": { "$type": "fontStyle", "$value": "{font.style.normal}" },
        "font": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{font.family.sans}",
            "fontSize": "{typography.body.large.fontSize}",
            "lineHeight": "{typography.body.large.lineHeight}",
            "fontWeight": "{typography.body.large.fontWeight}"
