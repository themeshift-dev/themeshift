{
  "font": {
    "family": {
      "$type": "fontFamily",

      "sans": {
        "$value": "'Helvetica Neue', system-ui, sans-serif",
        "$description": "Primary UI font"
      },

      "serif": { "$value": "Georgia, serif", "$description": "Editorial font" },

      "mono": {
        "$value": "ui-monospace, SFMono-Regular, Menlo, monospace",
        "$description": "Monospace code font"
      },

      "default": {
        "$value": "{font.family.sans}",
        "$description": "Default font-family for UI text"
      },

      "display": {
        "$value": "Georgia, serif",
        "$description": "Display font for hero and editorial headings"
      }
    },

    "weight": {
      "$type": "fontWeight",

      "light": { "$value": "300" },
      "regular": { "$value": "400" },
      "medium": { "$value": "500" },
      "semiBold": { "$value": "600" },
      "bold": { "$value": "700" }
    },

    "style": {
      "$type": "fontStyle",

      "normal": { "$value": "normal" },
      "italic": { "$value": "italic" }
    }
  },

  "typography": {
    "body": {
      "small": {
        "fontSize": { "$type": "fontSize", "$value": "0.875rem" },
        "lineHeight": { "$type": "lineHeight", "$value": "1.25rem" },
        "letterSpacing": { "$type": "letterSpacing", "$value": "0.01em" },
        "fontWeight": {
          "$type": "fontWeight",
          "$value": "{font.weight.regular}"
        },
        "fontStyle": { "$type": "fontStyle", "$value": "{font.style.normal}" },
        "font": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{font.family.sans}",
            "fontSize": "{typography.body.small.fontSize}",
            "lineHeight": "{typography.body.small.lineHeight}",
            "fontWeight": "{typography.body.small.fontWeight}"
          }
        }
      },

      "medium": {
        "fontSize": { "$type": "fontSize", "$value": "1rem" },
        "lineHeight": { "$type": "lineHeight", "$value": "1.375rem" },
        "letterSpacing": { "$type": "letterSpacing", "$value": "0.01em" },
        "fontWeight": {
          "$type": "fontWeight",
          "$value": "{font.weight.regular}"
        },
        "fontStyle": { "$type": "fontStyle", "$value": "{font.style.normal}" },
        "font": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{font.family.sans}",
            "fontSize": "{typography.body.medium.fontSize}",
            "lineHeight": "{typography.body.medium.lineHeight}",
            "fontWeight": "{typography.body.medium.fontWeight}"
          }
        }
