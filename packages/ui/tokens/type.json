        "fontWeight": {
          "$type": "fontWeight",
          "$value": "{font.weight.medium}"
        },
        "fontStyle": { "$type": "fontStyle", "$value": "{font.style.normal}" },
        "font": {
          "$type": "typography",
          "$value": {
            "fontFamily": "{font.family.sans}",
            "fontSize": "{typography.label.small.fontSize}",
