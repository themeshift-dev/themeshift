        "fontSize": { "$type": "fontSize", "$value": "1.125rem" },
        "lineHeight": { "$type": "lineHeight", "$value": "1.5rem" },
        "letterSpacing": { "$type": "letterSpacing", "$value": "0.01em" },
        "fontWeight": {
          "$type": "fontWeight",
          "$value": "{font.weight.medium}"
