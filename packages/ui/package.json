{
  "name": "@themeshift/ui",
  "version": "0.4.0",
  "description": "ThemeShift UI makes creating your own theme-aware components easy as pie 🥧",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:themeshift-dev/themeshift.git",
    "directory": "packages/ui"
