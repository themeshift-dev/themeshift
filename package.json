{
  "name": "@themeshift/workspace",
  "description": "ThemeShift monorepo for UI components, design tokens, and Vite tooling.",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": "24.11.1"
  },
  "scripts": {
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "build-storybook": "turbo run build-storybook --filter=@themeshift/ui",
    "build:ui-demo": "turbo run build --filter=@themeshift/ui-demo...",
    "build:audit": "pnpm -C packages/ui run build:audit",
    "build:ui-app": "turbo run build --filter=@themeshift/ui-app...",
    "build:ui": "turbo run build --filter=@themeshift/ui...",
    "build": "turbo run build",
    "ci:validate": "turbo run lint typecheck test build --affected",
    "dev:ui-app": "pnpm --filter @themeshift/vite-plugin build && pnpm --filter @themeshift/ui build && pnpm --filter @themeshift/ui-app dev",
    "dev:ui-demo": "pnpm --filter @themeshift/core build && pnpm --filter @themeshift/next build && pnpm --filter @themeshift/ui build && pnpm --filter @themeshift/ui-demo dev",
    "dev": "turbo run dev --parallel",
    "docs:check-badges": "node scripts/update-ui-component-badge.mjs --check",
    "docs:collect-component-data": "node scripts/docs/collect-component-data.mjs",
    "docs:collect-hook-data": "node scripts/docs/collect-hook-data.mjs",
    "docs:update-badges": "node scripts/update-ui-component-badge.mjs",
    "format": "prettier --write",
    "lint": "turbo run lint",
    "make:component": "pnpm -C packages/ui run make:component",
    "make:icon": "pnpm -C packages/ui run make:icon",
    "make:tokens": "pnpm -C packages/ui run make:tokens",
    "pr:check-conventions": "node scripts/check-pr-conventions.mjs",
    "release:preflight:verbose": "node scripts/preflight.ts --verbose",
    "release:preflight": "node scripts/preflight.ts",
    "storybook": "turbo run storybook --filter=@themeshift/ui",
    "test:coverage": "pnpm -r --no-bail --filter \"./packages/*\" --filter \"./apps/*\" --if-present run test:coverage",
    "test:packages": "turbo run test --filter=./packages/*",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "chalk": "^4.1.2",
    "ora": "^8.2.0",
    "prettier": "3.8.1",
    "turbo": "^2.5.8",
    "typescript": "~5.9.3"
  }
}
